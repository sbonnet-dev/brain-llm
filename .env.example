# Application settings
APP_NAME=brain-llm
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database (SQLite by default)
DATABASE_URL=sqlite:///./data/brain_llm.db

# Default endpoints for local model providers
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8001/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Public URL used when generating the Postman collection
PUBLIC_BASE_URL=http://localhost:8000

# Vector store (Qdrant)
QDRANT_URL=http://localhost:6333
#QDRANT_API_KEY=

# Knowledge & tool storage
KNOWLEDGE_STORAGE_DIR=./data/knowledge
TOOL_STORAGE_DIR=./data/tools

# Extracter (Apache Tika REST) — used to extract text + chunks from
# any uploaded knowledge file (pdf, docx, pptx, xlsx, txt, md, csv, …)
# before embedding.
EXTRACTER_URL=http://localhost:9002
#EXTRACTER_API_KEY=
EXTRACTER_CHUNK_SIZE=1000
EXTRACTER_CHUNK_OVERLAP=100
EXTRACTER_TIMEOUT_S=120
